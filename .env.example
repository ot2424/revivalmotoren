# Cloudflare / Worker / R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_R2_BUCKET=teuto-contact-uploads
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Mail / Versand
RESEND_API_KEY=
MAIL_FROM=anfrage@mail.teutomotoren.de
MAIL_TO_INFO=info@teutomotoren.de
MAIL_TO_INTERNAL=
MAIL_REPLY_FALLBACK=info@teutomotoren.de
DOWNLOAD_TOKEN_SECRET=

# Formular / Upload-Regeln
CONTACT_UPLOAD_MAX_FILES=5
CONTACT_UPLOAD_MAX_FILE_SIZE_MB=8
CONTACT_UPLOAD_MAX_TOTAL_SIZE_MB=20
CONTACT_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf,image/heic,image/heif
CONTACT_UPLOAD_RETENTION_HOURS=72
CONTACT_UPLOAD_LINK_TTL_SECONDS=259200

# Formular-Routing
CONTACT_DEFAULT_ROUTE=info
CONTACT_ROUTE_INFO=info@teutomotoren.de
CONTACT_ROUTE_INTERNAL=

# Sicherheit / Missbrauchsschutz
CONTACT_HONEYPOT_FIELD=website
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_MAX_REQUESTS=5
